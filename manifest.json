{
  "manifest_version": 3,
  "name": "Phishing Detector",
  "version": "1.0",

  "permissions": ["tabs", "scripting"],

  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}